{
  "name": "flowg",
  "version": "0.0.0-internal",
  "private": true,
  "type": "module",
  "scripts": {
    "i18n:format": "msgcat --sort-output --no-wrap src/locales/en.po -o src/locales/en.po && msgcat --sort-output --no-wrap src/locales/dummy.po -o src/locales/dummy.po",
    "i18n:compile": "npm run i18n:format && mkdir -p static/assets/locales/en static/assets/locales/dummy && i18next-conv -l en -s src/locales/en.po -t static/assets/locales/en/translation.json && i18next-conv -l dummy -s src/locales/dummy.po -t static/assets/locales/dummy/translation.json",
    "predev": "npm run i18n:compile",
    "dev": "vite",
    "build": "npm run i18n:compile && tsc -b && vite build",
    "build:dev": "npm run i18n:compile && tsc -b && vite build --mode development",
    "lint": "oxlint . && prettier --check .",
    "format": "oxlint --fix . && prettier --write ."
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.3.0",
    "@monaco-editor/react": "^4.7.0",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.1.2",
    "@mui/x-date-pickers": "^9.10.0",
    "@xyflow/react": "^12.11.2",
    "ag-grid-react": "^36.0.2",
    "dagre": "^0.8.5",
    "dayjs": "^1.11.21",
    "event-source-plus": "^0.1.15",
    "i18next": "^26.3.6",
    "i18next-http-backend": "^4.0.0",
    "react": "^19.2.8",
    "react-apexcharts": "^2.1.1",
    "react-dom": "^19.2.8",
    "react-i18next": "^17.0.8",
    "react-router": "^8.2.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/dagre": "^0.7.54",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "autoprefixer": "^10.5.4",
    "globals": "^17.7.0",
    "i18next-conv": "^17.0.0",
    "oxlint": "^1.75.0",
    "prettier": "^3.9.6",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-plugin-compression2": "^2.5.3"
  },
  "overrides": {
    "dompurify": "3.4.10",
    "i18next": {
      "typescript": "$typescript"
    }
  }
}
