{
  "name": "flowg",
  "version": "0.0.0-internal",
  "private": true,
  "type": "module",
  "scripts": {
    "i18n:compile": "mkdir -p static/assets/locales/en && i18next-conv -l en -s src/locales/en.po -t static/assets/locales/en/translation.json",
    "predev": "npm run i18n:compile",
    "dev": "vite",
    "build": "npm run i18n:compile && tsc -b && vite build",
    "build:dev": "npm run i18n:compile && tsc -b && vite build --mode development",
    "lint": "oxlint . && prettier --check .",
    "format": "oxlint --fix . && prettier --write ."
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.10",
    "@monaco-editor/react": "^4.7.0",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.1.2",
    "@mui/x-date-pickers": "^9.9.0",
    "@xyflow/react": "^12.11.2",
    "ag-grid-react": "^36.0.1",
    "dagre": "^0.8.5",
    "dayjs": "^1.11.21",
    "event-source-plus": "^0.1.15",
    "i18next": "^26.3.4",
    "i18next-http-backend": "^4.0.0",
    "react": "^19.2.7",
    "react-apexcharts": "^2.1.1",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/dagre": "^0.7.54",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.3",
    "globals": "^17.7.0",
    "oxlint": "^1.74.0",
    "prettier": "^3.9.5",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-compression2": "^2.5.3"
  },
  "overrides": {
    "dompurify": "3.4.10"
  }
}
